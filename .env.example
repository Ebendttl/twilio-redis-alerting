# =============================================================================
# Twilio Credentials
# Find these at: https://console.twilio.com/ (Account Info section on dashboard)
# Leave as placeholder values to run in MOCK/SIMULATION mode (no real SMS sent).
# =============================================================================

# Your Twilio Account SID — starts with "AC", 34 characters total.
# Location: Twilio Console > Account Info > Account SID
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your Twilio Auth Token — 32 hex characters.
# Location: Twilio Console > Account Info > Auth Token (click "Show")
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your Twilio phone number — must be E.164 format (+<country><number>).
# Location: Twilio Console > Phone Numbers > Manage > Active Numbers
# For trial accounts, this is the number Twilio assigned you at signup.
TWILIO_PHONE_NUMBER=+15017122661

# =============================================================================
# Alert Recipient
# =============================================================================

# The phone number that receives SMS alerts — must be E.164 format.
# For Twilio trial accounts, this MUST be a verified number.
# Verify at: Twilio Console > Phone Numbers > Manage > Verified Caller IDs
ALERT_RECIPIENT_PHONE_NUMBER=+1234567890

# =============================================================================
# Infrastructure
# =============================================================================

# Redis connection URL. Default assumes local Redis via docker compose up -d.
REDIS_URL=redis://127.0.0.1:6379
